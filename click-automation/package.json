{
  "name": "click-automation",
  "version": "1.0.0",
  "description": "Automação de cliques para E-CRV SP",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "capture": "node capture-clicks.js",
    "capture:ecrv": "node capture-clicks.js --url \"https://www.e-crvsp.sp.gov.br/\"",
    "run": "node run-automation.js",
    "ecrv": "node run-ecrv.js",
    "ecrv:login": "npm run ecrv -- --cpf 44922011811 --pin 1234",
    "ecrv:refresh": "node run-ecrv-with-refresh.js",
    "save-session": "node save-jsessionid.js",
    "extract-session": "node extract-jsessionid.js"
  },
  "keywords": ["automation", "mouse", "clicks", "windows", "powershell", "ecrv"],
  "author": "",
  "license": "ISC",
  "dependencies": {
  "mysql2": "^3.11.5",
  "playwright": "^1.57.0",
  "puppeteer": "^23.11.1"
}
}
